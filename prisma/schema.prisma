generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── Users ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         Role           @default(STUDENT)
  bio          String?
  sessions     QMSession[]
  classes      ClassStudent[]
  teaching     Class[]
  progress     VideoProgress[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// ─── Classes ──────────────────────────────────────────────────────────────────

model Class {
  id        String         @id @default(cuid())
  name      String
  code      String         @unique
  teacherId String
  teacher   User           @relation(fields: [teacherId], references: [id])
  students  ClassStudent[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([teacherId])
}

model ClassStudent {
  classId   String
  studentId String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@id([classId, studentId])
}

// ─── WordCatch (video lessons) ────────────────────────────────────────────────

model Topic {
  id          String   @id @default(cuid())
  title       String
  description String?
  level       String?
  tags        String[]
  videos      Video[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Video {
  id          String          @id @default(cuid())
  topicId     String
  title       String
  description String?
  videoUrl    String
  order       Int             @default(0)
  topic       Topic           @relation(fields: [topicId], references: [id], onDelete: Cascade)
  questions   Question[]
  progress    VideoProgress[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([topicId])
}

model VideoProgress {
  id          String    @id @default(cuid())
  userId      String
  videoId     String
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  video       Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, videoId])
  @@index([userId])
}

// ─── QuestionMaker ────────────────────────────────────────────────────────────

enum QMQuestionType {
  MULTIPLE_OPTION
  OPEN_ANSWER
  MATCHER
  CLASSIFIER
  FILL_BLANK
  TRUE_FALSE
  SENTENCE_ORDER
  WORD_SCRAMBLE
  FLASHCARD
}

enum QMSessionMode {
  PRACTICE
  TEST
  GAME
}

model QMTopic {
  id          String       @id @default(cuid())
  title       String
  description String?
  order       Int          @default(0)
  questions   QMQuestion[]
  sessions    QMSession[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model QMQuestion {
  id        String         @id @default(cuid())
  topicId   String
  topic     QMTopic        @relation(fields: [topicId], references: [id], onDelete: Cascade)
  order     Int
  type      QMQuestionType
  prompt    String
  data      Json
  answers   QMAnswer[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([topicId])
}

model QMSession {
  id          String        @id @default(cuid())
  topicId     String
  userId      String?
  mode        QMSessionMode @default(PRACTICE)
  topic       QMTopic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  answers     QMAnswer[]
  completedAt DateTime?
  createdAt   DateTime      @default(now())

  @@index([topicId])
  @@index([userId])
}

model QMAnswer {
  id         String     @id @default(cuid())
  sessionId  String
  session    QMSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionId String
  question   QMQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer     Json
  isCorrect  Boolean?
  reviewedAt DateTime?
  createdAt  DateTime   @default(now())
}

// ─── Learn With Me ────────────────────────────────────────────────────────────

model Question {
  id                String           @id @default(cuid())
  videoId           String
  prompt            String
  order             Int
  checkpointSeconds Int              @default(0)
  video             Video            @relation(fields: [videoId], references: [id], onDelete: Cascade)
  options           QuestionOption[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([videoId, order])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  order      Int
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([questionId, order])
}
